# valk-guard configuration
# Copy to .valk-guard.yaml and customize.

# Output format: terminal, json, sarif
format: terminal

# File patterns to exclude from scanning
exclude:
  - "vendor/**"
  - "*.gen.sql"
  - "testdata/**"

# Per-rule overrides
# rules:
#   VG001:
#     enabled: true
#     severity: error
#     engines: [all] # all | sql | go | goqu | sqlalchemy
#   VG002:
#     enabled: false
