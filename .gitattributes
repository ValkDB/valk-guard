# Normalize line endings to LF on checkout.
* text=auto eol=lf

# Explicitly mark source files.
*.go text eol=lf
*.py text eol=lf
*.sql text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Binary files.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
