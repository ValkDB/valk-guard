graph TD
    subgraph "CLI"
        CLI_CMD[valk-guard scan] --> CFG[Load Config]
    end

    subgraph "Extraction"
        CFG --> DISCOVER[Discover .sql/.go/.py Files]
        DISCOVER --> SQLSCAN[Raw SQL Scanner]
        DISCOVER --> GOSCAN[Go AST Scanner]
        DISCOVER --> GOQUSCAN[Goqu Scanner]
        DISCOVER --> PYSCAN[SQLAlchemy Scanner]
    end

    subgraph "Statements"
        SQLSCAN --> STMTS[SQLStatement Stream]
        GOSCAN --> STMTS
        GOQUSCAN --> STMTS
        PYSCAN --> STMTS
        STMTS --> META[Attach file line engine and disable directives]
    end

    subgraph "Analysis"
        META --> PARSER[postgresparser ParseSQL]
        PARSER --> AST[Parsed Query Metadata]
        CFG --> RULECFG[Rule config enabled severity engines]
        AST --> RULES[Rule engine VG001 to VG008]
        RULECFG --> RULES
        RULES --> FINDINGS[Findings]
    end

    subgraph "Reporting"
        FINDINGS --> REPORT{Reporter}
        REPORT --> TERM[Terminal]
        REPORT --> JSON[JSON]
        REPORT --> SARIF[SARIF 2 1 0]
    end
